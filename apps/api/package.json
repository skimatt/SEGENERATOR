{
  "name": "@segenerator/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint src tests --max-warnings=0",
    "pretest": "npm run template:create",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "template:create": "tsx scripts/create-template.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "@prisma/client": "^6.2.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "googleapis": "^173.0.0",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^4.1.10"
  }
}
